@namespace SSM

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        @* 💡 FocusOnNavigate를 삭제했습니다. 새로고침 시 라우팅 꼬임의 주범입니다. *@
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            @* 💡 혹시라도 경로를 못 찾았을 때 유저가 멍하니 있지 않게 안내 문구를 넣습니다. *@
            <div class="d-flex flex-column align-center justify-center mt-10">
                <MudText Typo="Typo.h6">페이지를 찾을 수 없거나 로딩 중입니다.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
                           OnClick="@(() => NavManager.NavigateTo("/my-raids", true))">메인으로 이동</MudButton>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    [Inject] private NavigationManager NavManager { get; set; } = default!;
}