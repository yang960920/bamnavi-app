@using MudBlazor
@using SSM.Services
@using SSM.Models
@inject Supabase.Client Supabase
@inject AppState AppState
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-4">정보를 변경하려면 현재 비밀번호 확인이 필요합니다.</MudAlert>

        <MudStack Spacing="3">
            @* 1. 모험단명 수정 *@
            <MudTextField @bind-Value="NewName"
                          Label="변경할 모험단명"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          HelperText="현재 이름이 기본으로 표시됩니다."
                          AutoFocus="true" />

            @* 3. 현재 비밀번호 확인 (필수) *@
            <MudTextField @bind-Value="CurrentPassword"
                          Label="현재 비밀번호 (확인용)"
                          Variant="Variant.Filled"
                          Margin="Margin.Dense"
                          InputType="InputType.Password"
                          Required="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          Color="Color.Primary" />

            @* 2. 비밀번호 수정 (선택 사항) *@
            <MudTextField @bind-Value="NewPassword"
                          Label="새 비밀번호 (변경 시에만 입력)"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputType="InputType.Password"
                          HelperText="변경하지 않으려면 비워두세요." />

            <MudTextField @bind-Value="ConfirmPassword"
                          Label="새 비밀번호 확인(변경 시에만 입력)"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputType="InputType.Password"
                          HelperText="변경하지 않으려면 비워두세요." />

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">취소</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">정보 수정 저장</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter] public string CurrentName { get; set; }

    public string NewName { get; set; }
    public string CurrentPassword { get; set; }
    public string NewPassword { get; set; }
    public string ConfirmPassword { get; set; }

    protected override void OnInitialized()
    {
        NewName = CurrentName;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        // 1. 유효성 검사 (MessageBox 알림)
        if (string.IsNullOrWhiteSpace(NewName))
        {
            await DialogService.ShowMessageBox("입력 오류", "모험단명은 비워둘 수 없습니다.", "확인");
            return;
        }

        if (string.IsNullOrWhiteSpace(CurrentPassword))
        {
            await DialogService.ShowMessageBox("인증 필요", "현재 비밀번호를 입력해야 변경이 가능합니다.", "확인");
            return;
        }

        if (!string.IsNullOrWhiteSpace(NewPassword) && NewPassword != ConfirmPassword)
        {
            await DialogService.ShowMessageBox("비밀번호 불일치", "새 비밀번호와 확인 입력이 일치하지 않습니다.", "확인");
            return;
        }

        try
        {
            // 2. 현재 비밀번호 검증 (DB 조회)
            var result = await Supabase.From<Adventure>()
                                       .Where(x => x.Id == AppState.CurrentUserId)
                                       .Where(x => x.Password == CurrentPassword)
                                       .Get();

            var user = result.Models.FirstOrDefault();

            if (user == null)
            {
                await DialogService.ShowMessageBox("인증 실패", "현재 비밀번호가 일치하지 않습니다.", "확인");
                return;
            }

            // 3. 정보 업데이트 로직
            user.AdventureName = NewName;

            // 새 비밀번호가 입력된 경우에만 비밀번호 교체
            if (!string.IsNullOrWhiteSpace(NewPassword))
            {
                user.Password = NewPassword;
            }

            await Supabase.From<Adventure>().Update(user);

            await DialogService.ShowMessageBox("수정 완료", "모험단 정보가 안전하게 변경되었습니다.", "확인");
            MudDialog.Close(DialogResult.Ok(NewName));
        }
        catch (Exception ex)
        {
            await DialogService.ShowMessageBox("시스템 오류", ex.Message, "확인");
        }
    }
}